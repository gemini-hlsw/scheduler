# Stage 0: Build frontend
FROM node:lts-alpine AS builder
RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app
RUN mkdir -p frontend/
COPY package*.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY frontend/package*.json frontend/
RUN pnpm install
COPY frontend/ frontend/
# backend/scheduler.graphql must be committed and up-to-date before building.
# To regenerate: uv run python scripts/export_graphql_schema.py
COPY backend/scheduler.graphql backend/
ARG VITE_API_URL=http://localhost:8001/graphql
ARG VITE_REALTIME_API_URL=http://localhost:8000/graphql
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_REALTIME_API_URL=$VITE_REALTIME_API_URL
# || true: codegen.yml fetches a live weather URL; fall back to committed src/gql/ if unreachable
RUN pnpm frontend codegen --config codegen.yml || true
RUN pnpm frontend build

# Stage 1: Serve with Nginx
FROM nginx:stable-alpine AS production
COPY --from=builder /app/frontend/dist /usr/share/nginx/html
COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
