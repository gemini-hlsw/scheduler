# Copy to .env — never commit .env
APP_VERSION=development

# Also set collector.with_redis: true in backend/scheduler/config.yaml
REDISCLOUD_URL=

# CloudCube / S3 ephemerides (optional)
CLOUDCUBE_URL=
CLOUDCUBE_ACCESS_KEY_ID=
CLOUDCUBE_SECRET_ACCESS_KEY=

# GPP connection token
GPP_DEVELOPMENT_TOKEN= # Only if gpp-client dev version is installed
GPP_TOKEN=

# Scheduler mode: VALIDATION/SIMULATION/REALTIME
SCHEDULER_MODE=

# Database URL matching HEROKU env connection.
DATABASE_URL=postgresql+asyncpg://scheduler:scheduler_dev@localhost:5433/scheduler


# Used by docker-compose to provision the postgres service.
DB_USER=scheduler
DB_PASSWORD=scheduler_dev
DB_NAME=scheduler

# Connection pool tuning (optional).
DB_POOL_SIZE=5
DB_POOL_OVERFLOW=10
DB_ECHO_SQL=false

# Weather URL service
WEATHER_URL= # Frontend endpoint to external weather service
VITE_WEATHER_URL= # Frontend endpoint to external weather service
