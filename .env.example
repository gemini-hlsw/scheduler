# Copy to .env — never commit .env
APP_VERSION=development

# Also set collector.with_redis: true in backend/scheduler/config.yaml
REDISCLOUD_URL=

# CloudCube / S3 ephemerides (optional)
CLOUDCUBE_URL=
CLOUDCUBE_ACCESS_KEY_ID=
CLOUDCUBE_SECRET_ACCESS_KEY=

# Scheduler mode: VALIDATION/SIMULATION/REALTIME
SCHEDULE_MODE=