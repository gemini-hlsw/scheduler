{
  "name": "scheduler",
  "description": "Monorepo for scheduler projects",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "license": "BSD-3-Clause",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gemini-hlsw/scheduler.git"
  },
